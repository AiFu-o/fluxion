{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "noEmit": true,
        "types": ["node"],
        "baseUrl": ".",
        "paths": {
            "@fluxion/shared": ["../../packages/shared/src"],
            "@fluxion/reactivity": ["../../packages/reactivity/src"],
            "@fluxion/runtime-core": ["../../packages/runtime-core/src"],
            "@fluxion/runtime-dom": ["../../packages/runtime-dom/src"],
            "@fluxion/compiler-core": ["../../packages/compiler-core/src"],
            "@fluxion/compiler-dom": ["../../packages/compiler-dom/src"],
            "@fluxion/compiler-nui": ["../../packages/compiler-nui/src"],
            "@fluxion/vite-plugin-fluxion": ["../../packages/vite-plugin-fluxion/src"],
            "fluxion": ["../../packages/fluxion/src"],
            "fluxion-runtime": ["../../packages/runtime-dom/src"]
        }
    },
    "include": [
        "src/**/*.ts",
        "vite.config.ts",
        "../../packages/vite-plugin-fluxion/src/nui.d.ts"
    ]
}