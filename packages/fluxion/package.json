{
    "name": "fluxion",
    "version": "0.0.1",
    "type": "module",
    "description": "A lightweight AI-friendly UI framework",
    "main": "./dist/fluxion.cjs",
    "module": "./dist/fluxion.js",
    "types": "./dist/fluxion.d.ts",
    "exports": {
        ".": {
            "import": "./dist/fluxion.js",
            "require": "./dist/fluxion.cjs",
            "types": "./dist/fluxion.d.ts"
        },
        "./runtime": {
            "import": "./dist/fluxion-runtime.js",
            "require": "./dist/fluxion-runtime.cjs",
            "types": "./dist/fluxion-runtime.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "dependencies": {
        "@fluxion/runtime-dom": "workspace:*",
        "@fluxion/runtime-core": "workspace:*",
        "@fluxion/reactivity": "workspace:*",
        "@fluxion/shared": "workspace:*"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/AiFu-o/fluxion"
    },
    "keywords": [
        "ui",
        "framework",
        "reactive",
        "signal",
        "ai-friendly"
    ],
    "author": "Fluxion Team",
    "license": "MIT"
}